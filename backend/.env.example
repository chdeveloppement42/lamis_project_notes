# ─── Database ─────────────────────────────────────────────────────────────────
# Add ?connection_limit=10 on PaaS (Supabase free = 20 connections max)
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/immo_lamis?schema=public&connection_limit=10"

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 16 characters. Use: openssl rand -base64 32
JWT_SECRET="replace-with-a-strong-random-secret-min-16-chars"
JWT_EXPIRES_IN="1d"
# Must be different from JWT_SECRET. Use: openssl rand -base64 32
JWT_REFRESH_SECRET="replace-with-a-different-strong-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"
NODE_ENV="production"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:5174"

# ─── Storage ───────────────────────────────────────────────────────────────────
# Use "disk" for local development, "cloudinary" for production
STORAGE_PROVIDER="disk"
UPLOAD_DIR="./uploads"

# Required only when STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
